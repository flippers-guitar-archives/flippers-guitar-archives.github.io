---
import { ui, localePath, stripLocalePrefix, type Locale } from '../lib/i18n';

interface Props {
  lang: Locale;
  title?: string;
}

const { lang, title } = Astro.props;
const t = ui[lang];
const otherLang: Locale = lang === 'ja' ? 'en' : 'ja';
const otherLangUrl = localePath(otherLang, stripLocalePrefix(Astro.url.pathname));
const homeUrl = localePath(lang, '/');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} — ${t.siteTitle}` : t.siteTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href={homeUrl}>{t.siteTitle}</a>
      <nav class="site-nav">
        <a href={localePath(lang, '/')} class:list={['nav-link', { current: !Astro.url.pathname.match(/^\/(en\/)?(live|media)/) }]}>{t.discography}</a>
        <a href={localePath(lang, '/live')} class:list={['nav-link', { current: !!Astro.url.pathname.match(/^\/(en\/)?live/) }]}>{t.live}</a>
        <a href={localePath(lang, '/media')} class:list={['nav-link', { current: !!Astro.url.pathname.match(/^\/(en\/)?media/) }]}>{t.media}</a>
        <span class="nav-spacer"></span>
        <a class="lang-switch" href={otherLangUrl} hreflang={otherLang}>{t.switchLang}</a>
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <p><a href="https://flippers-guitar.github.io">flippers-guitar.github.io</a></p>
    </footer>
    <style is:global>
      :root {
        --color-fg: #1a1a1a;
        --color-fg-dim: #666;
        --color-bg: #fafafa;
        --color-accent: #c4302b;
        --color-rule: #e0e0e0;
        --max-width: 760px;
        font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Kaku Gothic ProN',
          'Yu Gothic', 'Meiryo', sans-serif;
      }
      body {
        margin: 0;
        background: var(--color-bg);
        color: var(--color-fg);
        line-height: 1.7;
      }
      a { color: var(--color-accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--color-rule);
        max-width: var(--max-width);
        margin: 0 auto;
      }
      .site-title {
        font-weight: 600;
        color: var(--color-fg);
        font-size: 1rem;
      }
      .site-nav {
        display: flex;
        gap: 1.25rem;
        align-items: baseline;
      }
      .nav-link {
        font-size: 0.875rem;
        color: var(--color-fg-dim);
      }
      .nav-link.current {
        color: var(--color-fg);
        font-weight: 500;
      }
      .nav-spacer {
        flex: 0 0 0.5rem;
        border-left: 1px solid var(--color-rule);
        align-self: stretch;
      }
      .lang-switch {
        font-size: 0.875rem;
        color: var(--color-fg-dim);
      }
      .site-main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
      .site-footer {
        max-width: var(--max-width);
        margin: 4rem auto 2rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--color-rule);
        color: var(--color-fg-dim);
        font-size: 0.875rem;
      }
      h1, h2, h3 { line-height: 1.3; }
    </style>
  </body>
</html>
