---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiveList from '../../components/LiveList.astro';
import { ui } from '../../lib/i18n';

const entries = await getCollection('live');
const t = ui.ja;
---
<BaseLayout lang="ja" title={t.live}>
  <LiveList entries={entries} lang="ja" />
</BaseLayout>
